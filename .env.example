# Server
PORT=4000
NODE_ENV=development

# CORS — storefront origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Fonnte — WhatsApp API (Indonesia gateway, no Twilio)
# Register at https://fonnte.com → device → copy TOKEN
FONNTE_TOKEN=
# Optional override (default: https://api.fonnte.com/send)
# FONNTE_API_URL=https://api.fonnte.com/send

# Message body (use {{code}}) — appears from the WhatsApp number linked in Fonnte
OTP_MESSAGE_TEMPLATE=Alma Cosmetics — رمز التحقق: {{code}} (صالح 5 دقائق). لا تشاركي هذا الرمز.

# Local testing only: JSON includes "debugCode" — NEVER true on production
OTP_DEV_REVEAL=false
