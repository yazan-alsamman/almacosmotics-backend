# Server
PORT=4000
NODE_ENV=development

# CORS — storefront origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# WhatsApp OTP via Twilio (optional — leave empty to log OTP in server console only)
# https://www.twilio.com/docs/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Must be a Twilio-approved WhatsApp sender, usually: whatsapp:+14155238886 (sandbox) or your business number
TWILIO_WHATSAPP_FROM=whatsapp:+963XXXXXXXXX

# Message body (use {{code}})
OTP_MESSAGE_TEMPLATE=Alma Cosmetics — رمز التحقق: {{code}} (صالح 5 دقائق)

# Local testing only: JSON includes "debugCode" — NEVER true on production
OTP_DEV_REVEAL=false
